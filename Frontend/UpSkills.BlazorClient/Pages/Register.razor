@page "/register"

<PageTitle>Registro</PageTitle>

<div class="sub_page">
<div class="hero_area">
	<NavMenu />
</div>

	<!-- register.html section -->
	<section class="contact_section layout_padding">
		<div class="container contact_heading">
			<h2>
				Crea tu cuenta
			</h2>
			<p>
				Completa los campos para crear tu cuenta y comenzar a aprender con nosotros.
			</p>
		</div>
		<div class="container">
			<form>
				<div class="form-row">
					<div class="form-group col-md-6">
						<label for="name">Nombre</label>
						<input type="text" class="form-control" id="name" value="@FormData.PrimerNombre" />
					</div>
					<div class="form-group col-md-6">
						<label for="second-name">Segundo nombre</label>
						<input type="text" class="form-control" id="second-name" value="@FormData.SegundoNombre" />
					</div>
					
				</div>

				<div class="form-row">
					<div class="form-group col-md-6">
						<label for="inputName4">Apellido</label>
						<input type="text" class="form-control" id="inputName4" value="@FormData.PrimerApellido" />
					</div>
					<div class="form-group col-md-6">
						<label for="inputEmail4">Segundo Apellido</label>
						<input type="text" class="form-control" id="inputEmail4" value="@FormData.SegundoApellido" />
					</div>

				</div>

				<div class="form-row">
					<div class="form-group col-md-12">
						<label for="inputName4">Correo</label>
						<input type="email" class="form-control" id="inputName4" value="@FormData.Correo" />
					</div>
				</div>

				<div class="form-row">
					<div class="form-group col-md-6">
						<label for="inputNumber4">Rol</label>
						<select id="inputState" class="form-control" onchange="() => @FormData.Rol">
							<option selected disabled>seleccione..</option>
							@foreach (var item in IERoles)
							{
								<option value="@item.Id">@item.Nombre</option>
							}
						</select>
					</div>
					<div class="form-group col-md-6">
						<label for="inputState">Seleciona tu pais</label>
						<select id="inputState" class="form-control" onchange="() => @FormData.Pais">
							<option selected disabled>seleccione..</option>
							@foreach (var item in IEPaises)
							{
								<option value="@item.Id">@item.Nombre</option>
							}
						</select>
					</div>
					
				</div>

				<div class="form-row">
					<div class="form-group col-md-6">
						<label for="inputName4">Contraseña</label>
						<input type="text" class="form-control" id="inputName4" value="@FormData.Contrasena" />
					</div>
					<div class="form-group col-md-6">
						<label for="inputEmail4">Confirmar contraseña</label>
						<input type="text" class="form-control" id="inputEmail4" value="@FormData.Contrasena" />
					</div>

				</div>

				<div class="d-flex justify-content-center">
					<button type="button" class="" @onclick="RegistrateUser">Registrarse</button>
				</div>
			</form>

		</div>
		
	</section>
</div>
