@page "/login"

<PageTitle>Login</PageTitle>
<div class="sub_page">
<div class="hero_area">
	<NavMenu />
</div>
<!-- login.html section -->
<section class="contact_section layout_padding">
	<div class="container contact_heading">
		<h2>
			Ingresa a tu cuenta
		</h2>
		<p>
			Completa los campos para ingresar a tu cuenta, si no tienes una cuenta, registrate para empezar a aprender con nosotros.
		</p>
	</div>
	<div class="container">
		<form>
			<div class="form-row">
				<div class="form-group col-md-6">
					<label for="email">Email</label>
					<input type="email" class="form-control" id="email" />
				</div>
				<div class="form-group col-md-6">
					<label for="password">Contraseña</label>
					<input type="password" class="form-control" id="password" />
				</div>
			</div>

			<div class="d-flex justify-content-center">
				<button type="submit" class="btn btn-outline-primary">Ingresar</button>
			</div>
			<div class="d-flex justify-content-center">
				<button type="button" class="btn btn-outline-primary" onclick="window.location.href='register'">Registro</button>
			</div>
		</form>
	</div>

</section>
<!-- end login.html section -->
</div>